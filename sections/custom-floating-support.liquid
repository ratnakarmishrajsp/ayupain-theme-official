{% comment %}
  Aayu Pain - Floating WhatsApp/Phone Order Support & Sticky Mobile Buy Bar
{% endcomment %}

{% if section.settings.enable_support %}
  <div class="aayu-floating-support">
    {% if section.settings.whatsapp_number != blank %}
      <a
        href="https://wa.me/{{ section.settings.whatsapp_number }}?text=Hello%20AayuPain%20Support,%20I%20want%20to%20order%20AyuPain%20Relief%20Oil"
        target="_blank"
        rel="noopener"
        class="aayu-support-btn aayu-support-whatsapp"
        aria-label="Order via WhatsApp"
        title="Order via WhatsApp"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
      </a>
    {% endif %}

    {% if section.settings.phone_number != blank %}
      <a
        href="tel:{{ section.settings.phone_number }}"
        class="aayu-support-btn aayu-support-phone"
        aria-label="Call for Order Support"
        title="Call for Order Support"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
    {% endif %}
  </div>
{% endif %}

<style>
  .aayu-floating-support {
    position: fixed;
    bottom: 25px;
    right: 20px;
    z-index: 98;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .aayu-support-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    transition: transform 0.2s ease;
    text-decoration: none;
  }
  .aayu-support-btn:hover {
    transform: scale(1.1);
  }
  .aayu-support-whatsapp {
    background: #25D366;
  }
  .aayu-support-phone {
    background: #0e5a36;
  }
</style>

{% schema %}
{
  "name": "Floating Support Widget",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_support",
      "label": "Enable Floating Support Buttons",
      "default": true
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Order Number (with Country Code)",
      "default": "919876543210"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Order Number",
      "default": "+919876543210"
    }
  ],
  "presets": [
    {
      "name": "Floating Support Widget"
    }
  ]
}
{% endschema %}
