{% comment %}
  Aayu Pain - Floating Support Widget & Mobile Sticky Buy Bar Section
{% endcomment %}

{% if section.settings.enable_support %}
  <div class="aayu-floating-support">
    {% if section.settings.whatsapp_number != blank %}
      <a
        href="https://wa.me/{{ section.settings.whatsapp_number | remove: ' ' | remove: '+' }}?text={{ section.settings.whatsapp_message | url_encode }}"
        target="_blank"
        rel="noopener noreferrer"
        class="aayu-support-btn aayu-support-whatsapp"
        aria-label="Order via WhatsApp"
        title="WhatsApp Support"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.705 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
      </a>
    {% endif %}

    {% if section.settings.phone_number != blank %}
      <a
        href="tel:{{ section.settings.phone_number | remove: ' ' }}"
        class="aayu-support-btn aayu-support-phone"
        aria-label="Call for Order Support"
        title="Call Support"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
    {% endif %}
  </div>
{% endif %}

{% if section.settings.enable_sticky_bar and product != blank %}
  <div id="AayuStickyBuyBar" class="aayu-sticky-buy-bar">
    <div class="aayu-sticky-info">
      <span class="aayu-sticky-title">{{ product.title | escape }}</span>
      <span class="aayu-sticky-price">{{ product.price | money }}</span>
    </div>
    <button
      class="button button--primary aayu-sticky-cta btn-cod-pulsing"
      onclick="document.querySelector('.product-form__submit')?.scrollIntoView({ behavior: 'smooth' });"
    >
      ORDER NOW (COD AVAILABLE)
    </button>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const stickyBar = document.getElementById('AayuStickyBuyBar');
      const mainCTA = document.querySelector('.product-form__submit');
      
      if (stickyBar && mainCTA) {
        window.addEventListener('scroll', function() {
          const ctaPosition = mainCTA.getBoundingClientRect().top;
          if (ctaPosition < 0) {
            stickyBar.classList.add('is-visible');
          } else {
            stickyBar.classList.remove('is-visible');
          }
        });
      }
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "Floating Support & Sticky",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Floating Support Widget"
    },
    {
      "type": "checkbox",
      "id": "enable_support",
      "label": "Enable WhatsApp & Phone Floating Support",
      "default": true
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Number (with country code)",
      "default": "919876543210"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "Default WhatsApp Message",
      "default": "Hello! I need help ordering Aayu Pain Relief Oil."
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Support Number",
      "default": "+919876543210"
    },
    {
      "type": "header",
      "content": "Mobile Sticky Buy Bar"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_bar",
      "label": "Enable Mobile Sticky Buy Bar",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Floating Support & Sticky"
    }
  ]
}
{% endschema %}
