{% comment %}
  Aayu Pain - Pain Relief FAQ Accordion Section
{% endcomment %}

<div class="aayu-faq-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width page-width--narrow">
    <div class="aayu-faq-header text-center">
      {% if section.settings.sub_heading != blank %}
        <span class="aayu-subheading">{{ section.settings.sub_heading | escape }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="aayu-section-heading h1">{{ section.settings.heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="aayu-faq-accordion">
      {% for block in section.blocks %}
        <details class="aayu-faq-item" {{ block.shopify_attributes }}>
          <summary class="aayu-faq-question">
            <span>{{ block.settings.question | escape }}</span>
            <svg class="aayu-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="aayu-faq-answer">
            <p>{{ block.settings.answer | escape }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .aayu-subheading {
    display: inline-block;
    color: #cca43b;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  .aayu-section-heading {
    color: #0e5a36;
    margin: 0 0 1rem 0;
  }
  .aayu-faq-header {
    margin-bottom: 3rem;
    text-align: center;
  }
  .aayu-faq-accordion {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .aayu-faq-item {
    background: #ffffff;
    border-radius: 12px;
    border: 1px solid rgba(204, 164, 59, 0.25);
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .aayu-faq-item[open] {
    border-color: #cca43b;
  }
  .aayu-faq-question {
    padding: 1.8rem;
    font-size: 1.6rem;
    font-weight: 700;
    color: #1f2937;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    list-style: none;
  }
  .aayu-faq-question::-webkit-details-marker {
    display: none;
  }
  .aayu-faq-icon {
    color: #cca43b;
    transition: transform 0.2s ease;
  }
  .aayu-faq-item[open] .aayu-faq-icon {
    transform: rotate(180deg);
  }
  .aayu-faq-answer {
    padding: 0 1.8rem 1.8rem 1.8rem;
    font-size: 1.45rem;
    color: #4b5563;
    line-height: 1.65;
    border-top: 1px solid #f3f4f6;
  }
</style>

{% schema %}
{
  "name": "Pain Relief FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "GOT QUESTIONS?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How fast does AyuPain Oil start relieving pain?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "AyuPain Oil features deep-penetration Wintergreen & Eucalyptus oils that absorb within 3 to 5 minutes, delivering thermal warmth and rapid relief."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pain Relief FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How fast does AyuPain Oil start relieving pain?",
            "answer": "AyuPain Oil features deep-penetration Wintergreen & Eucalyptus oils that absorb within 3 to 5 minutes, delivering thermal warmth and rapid relief."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is it safe for daily use by elderly patients?",
            "answer": "Yes, 100%! AyuPain Oil is 100% Ayurvedic, Ayush-Certified, free from mineral oil, alcohol, and harmful chemicals. It is safe for daily long-term use."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is Cash on Delivery (COD) and Free Shipping available?",
            "answer": "Yes! We offer 100% Cash on Delivery (COD) and Free Shipping across all pincodes in India."
          }
        }
      ]
    }
  ]
}
{% endschema %}
