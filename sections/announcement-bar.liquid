{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign social_icons = false
  endif
  if section.settings.enable_country_selector or section.settings.enable_language_selector
    assign language_country_selector = true
  endif
  if section.blocks.size > 0
    assign announcement_bar = true
  endif
-%}

<div
  class="utility-bar color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator and section.blocks.size > 0 %} utility-bar--bottom-border{% elsif section.settings.show_line_separator and section.settings.show_social and social_icons%} utility-bar--bottom-border-social-only{% endif %}"
>
  <div class="aayu-marquee-wrapper">
    <div class="aayu-marquee-content">
      <span class="aayu-marquee-item">🌿 100% PURE AYURVEDIC PAIN RELIEF OIL &nbsp;&nbsp;•&nbsp;&nbsp; 🚚 FREE SHIPPING & CASH ON DELIVERY (COD) ACROSS INDIA &nbsp;&nbsp;•&nbsp;&nbsp; 🛡️ AYUSH CERTIFIED & 100% HERBAL &nbsp;&nbsp;•&nbsp;&nbsp; 🌿 100% PURE AYURVEDIC PAIN RELIEF OIL &nbsp;&nbsp;•&nbsp;&nbsp; 🚚 FREE SHIPPING & CASH ON DELIVERY (COD) ACROSS INDIA &nbsp;&nbsp;•&nbsp;&nbsp; 🛡️ AYUSH CERTIFIED & 100% HERBAL</span>
      <span class="aayu-marquee-item" aria-hidden="true">🌿 100% PURE AYURVEDIC PAIN RELIEF OIL &nbsp;&nbsp;•&nbsp;&nbsp; 🚚 FREE SHIPPING & CASH ON DELIVERY (COD) ACROSS INDIA &nbsp;&nbsp;•&nbsp;&nbsp; 🛡️ AYUSH CERTIFIED & 100% HERBAL &nbsp;&nbsp;•&nbsp;&nbsp; 🌿 100% PURE AYURVEDIC PAIN RELIEF OIL &nbsp;&nbsp;•&nbsp;&nbsp; 🚚 FREE SHIPPING & CASH ON DELIVERY (COD) ACROSS INDIA &nbsp;&nbsp;•&nbsp;&nbsp; 🛡️ AYUSH CERTIFIED & 100% HERBAL</span>
    </div>
  </div>
</div>

<style>
  .utility-bar {
    background: #093f25 !important;
    color: #ffffff !important;
    border-bottom: 1px solid #cca43b;
    overflow: hidden;
    padding: 10px 0 !important;
  }
  .aayu-marquee-wrapper {
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
    display: flex;
  }
  .aayu-marquee-content {
    display: flex;
    white-space: nowrap;
    animation: aayuMarquee 25s linear infinite;
  }
  .aayu-marquee-item {
    font-size: 1.35rem;
    font-weight: 700;
    color: #cca43b;
    letter-spacing: 1px;
    padding-right: 2rem;
  }
  @keyframes aayuMarquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .aayu-marquee-wrapper:hover .aayu-marquee-content {
    animation-play-state: paused;
  }
</style>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "t:sections.announcement-bar.blocks.announcement.settings.text.default",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
