{% comment %}
  AayuPain™ Official Contact Page Section with Email & Phone Support
{% endcomment %}

<div class="aayu-contact-page-wrapper">
  <div class="page-width">
    <!-- Header Banner -->
    <div class="aayu-contact-header">
      <span class="aayu-contact-badge">📞 24/7 CUSTOMER CARE</span>
      <h1 class="aayu-contact-title">Contact AyuPain™ Support</h1>
      <p class="aayu-contact-subtitle">Have questions about your order or our Ayurvedic Pain Relief Oil? We're here to help!</p>
    </div>

    <!-- Contact Info Grid Cards -->
    <div class="aayu-contact-grid">
      <!-- Card 1: Email Support -->
      <div class="aayu-contact-card">
        <div class="aayu-contact-icon-box">✉️</div>
        <h3>Email Support</h3>
        <p>Send us an email anytime. We respond within 24 hours.</p>
        <a href="mailto:support@ayupain.in" class="aayu-contact-link">support@ayupain.in</a>
      </div>

      <!-- Card 2: Phone Helpline -->
      <div class="aayu-contact-card">
        <div class="aayu-contact-icon-box">📞</div>
        <h3>Phone Helpline</h3>
        <p>Call our support team for order assistance.</p>
        <a href="tel:8197383570" class="aayu-contact-link">+91 8197383570</a>
      </div>

      <!-- Card 3: WhatsApp Support -->
      <div class="aayu-contact-card">
        <div class="aayu-contact-icon-box">💬</div>
        <h3>WhatsApp Support</h3>
        <p>Instant 1-tap chat for quick order & delivery updates.</p>
        <a href="https://wa.me/918197383570?text=Hello%20AyuPain%20Support,%20I%20have%20a%20query" target="_blank" rel="noopener" class="aayu-contact-link aayu-wa-link">Chat on WhatsApp</a>
      </div>

      <!-- Card 4: Operating Hours -->
      <div class="aayu-contact-card">
        <div class="aayu-contact-icon-box">⏰</div>
        <h3>Support Hours</h3>
        <p>Monday - Saturday: 9:00 AM to 7:00 PM IST</p>
        <span class="aayu-contact-status">🟢 Free COD Available</span>
      </div>
    </div>

    <!-- Contact Form Box -->
    <div class="aayu-contact-form-box">
      <h2 class="aayu-form-title">Send Us a Message</h2>
      <p class="aayu-form-sub">Fill out the form below and our Ayurvedic care team will get back to you shortly.</p>

      {%- form 'contact', id: 'AayuPageContactForm', class: 'aayu-contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="aayu-form-success">
            ✓ Thank you for contacting AyuPain™! Your message has been sent successfully. We will get back to you shortly.
          </div>
        {%- elsif form.errors -%}
          <div class="aayu-form-error">
            Please check the details entered and try again.
          </div>
        {%- endif -%}

        <div class="aayu-form-row">
          <div class="aayu-form-group">
            <label for="AayuContactName">Your Name *</label>
            <input type="text" id="AayuContactName" name="contact[name]" placeholder="Enter full name" required value="{% if form.name %}{{ form.name }}{% endif %}">
          </div>
          <div class="aayu-form-group">
            <label for="AayuContactEmail">Email Address *</label>
            <input type="email" id="AayuContactEmail" name="contact[email]" placeholder="support@ayupain.in" required value="{% if form.email %}{{ form.email }}{% endif %}">
          </div>
        </div>

        <div class="aayu-form-row">
          <div class="aayu-form-group">
            <label for="AayuContactPhone">Phone Number *</label>
            <input type="tel" id="AayuContactPhone" name="contact[phone]" placeholder="+91 8197383570" required value="{% if form.phone %}{{ form.phone }}{% endif %}">
          </div>
          <div class="aayu-form-group">
            <label for="AayuContactSubject">Subject</label>
            <input type="text" id="AayuContactSubject" name="contact[subject]" placeholder="Order Status / Query">
          </div>
        </div>

        <div class="aayu-form-group">
          <label for="AayuContactMessage">Your Message *</label>
          <textarea id="AayuContactMessage" name="contact[body]" rows="5" placeholder="How can we help you today?" required>{{ form.body }}</textarea>
        </div>

        <button type="submit" class="aayu-contact-submit-btn">Send Message 🚀</button>
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .aayu-contact-page-wrapper {
    padding: 40px 0 70px 0;
    background: #f8faf9;
    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .aayu-contact-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 40px auto;
  }
  .aayu-contact-badge {
    background: rgba(14, 90, 54, 0.1);
    color: #0e5a36;
    font-size: 12px;
    font-weight: 800;
    padding: 4px 14px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }
  .aayu-contact-title {
    color: #093f25;
    font-size: 32px;
    font-weight: 800;
    margin: 12px 0 8px 0;
  }
  .aayu-contact-subtitle {
    color: #4b5563;
    font-size: 15px;
    line-height: 1.5;
  }
  .aayu-contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 45px;
  }
  @media (max-width: 900px) {
    .aayu-contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 550px) {
    .aayu-contact-grid {
      grid-template-columns: 1fr;
    }
  }
  .aayu-contact-card {
    background: #ffffff;
    border: 1.5px solid #e5e7eb;
    border-radius: 16px;
    padding: 24px 20px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .aayu-contact-card:hover {
    transform: translateY(-4px);
    border-color: #0e5a36;
  }
  .aayu-contact-icon-box {
    font-size: 30px;
    margin-bottom: 12px;
  }
  .aayu-contact-card h3 {
    color: #093f25;
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 6px 0;
  }
  .aayu-contact-card p {
    color: #6b7280;
    font-size: 13px;
    margin: 0 0 14px 0;
    line-height: 1.4;
  }
  .aayu-contact-link {
    display: inline-block;
    background: #0e5a36;
    color: #ffffff;
    font-weight: 700;
    font-size: 14px;
    padding: 8px 16px;
    border-radius: 25px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .aayu-contact-link:hover {
    background: #093f25;

  }
  .aayu-wa-link {
    background: #25d366;
  }
  .aayu-wa-link:hover {
    background: #1eb957;
  }
  .aayu-contact-status {
    color: #059669;
    font-weight: 700;
    font-size: 13px;
  }
  .aayu-contact-form-box {
    background: #ffffff;
    border: 1.5px solid #e5e7eb;
    border-radius: 20px;
    padding: 35px;
    max-width: 800px;
    margin: 0 auto;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.05);
  }
  .aayu-form-title {
    color: #093f25;
    font-size: 24px;
    font-weight: 800;
    margin: 0 0 6px 0;
    text-align: center;
  }
  .aayu-form-sub {
    color: #6b7280;
    font-size: 14px;
    text-align: center;
    margin: 0 0 25px 0;
  }
  .aayu-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 600px) {
    .aayu-form-row {
      grid-template-columns: 1fr;
    }
  }
  .aayu-form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 16px;
  }
  .aayu-form-group label {
    font-size: 13px;
    font-weight: 700;
    color: #374151;
  }
  .aayu-form-group input,
  .aayu-form-group textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid #d1d5db;
    border-radius: 10px;
    font-size: 14px;
    font-family: inherit;
    transition: border-color 0.2s ease;
  }
  .aayu-form-group input:focus,
  .aayu-form-group textarea:focus {
    outline: none;
    border-color: #0e5a36;
  }
  .aayu-contact-submit-btn {
    width: 100%;
    background: linear-gradient(135deg, #093f25 0%, #0e5a36 100%);
    color: #ffffff;
    border: 1.5px solid #cca43b;
    border-radius: 30px;
    padding: 14px;
    font-size: 15px;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(14, 90, 54, 0.3);
    transition: transform 0.2s ease;
  }
  .aayu-contact-submit-btn:hover {
    transform: translateY(-2px);
  }
  .aayu-form-success {
    background: #d1fae5;
    color: #065f46;
    padding: 12px 16px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 20px;
  }
  .aayu-form-error {
    background: #fee2e2;
    color: #991b1b;
    padding: 12px 16px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 20px;
  }
</style>

{% schema %}
{
  "name": "Main Contact Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
