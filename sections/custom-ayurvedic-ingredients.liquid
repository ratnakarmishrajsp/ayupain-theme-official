{% comment %}
  Aayu Pain - Ayurvedic Key Ingredients & Deep Penetration Formula Section
{% endcomment %}

<div class="aayu-ingredients-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="aayu-ingredients-header text-center">
      {% if section.settings.sub_heading != blank %}
        <span class="aayu-subheading">{{ section.settings.sub_heading | escape }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="aayu-section-heading h1">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      <p class="aayu-section-desc">Formulated with 48+ Ayush-Certified pure Ayurvedic herbs & botanical oils for deep joint & muscle penetration.</p>
    </div>

    <div class="aayu-ingredients-grid">
      {% for block in section.blocks %}
        <div class="aayu-ingredient-card" {{ block.shopify_attributes }}>
          <div class="aayu-ingredient-badge">100% Pure</div>
          <div class="aayu-ingredient-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.5 10-10 10z"/></svg>
          </div>
          <h3 class="aayu-ingredient-title">{{ block.settings.title | escape }}</h3>
          <p class="aayu-ingredient-hindi">{{ block.settings.hindi_title | escape }}</p>
          <p class="aayu-ingredient-benefit">{{ block.settings.benefit | escape }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .aayu-ingredients-section {
    border-top: 1px solid rgba(204, 164, 59, 0.2);
    border-bottom: 1px solid rgba(204, 164, 59, 0.2);
  }
  .aayu-subheading {
    display: inline-block;
    color: #cca43b;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  .aayu-section-heading {
    color: #0e5a36;
    margin: 0 0 0.5rem 0;
  }
  .aayu-section-desc {
    font-size: 1.5rem;
    color: #4b5563;
    max-width: 650px;
    margin: 0 auto;
  }
  .aayu-ingredients-header {
    margin-bottom: 3.5rem;
    text-align: center;
  }
  .aayu-ingredients-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.8rem;
  }
  .aayu-ingredient-card {
    background: #ffffff;
    border-radius: 14px;
    padding: 2rem 1.5rem;
    border: 1px solid rgba(204, 164, 59, 0.25);
    box-shadow: 0 8px 20px rgba(0,0,0,0.04);
    text-align: center;
    position: relative;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .aayu-ingredient-card:hover {
    transform: translateY(-4px);
    border-color: #cca43b;
  }
  .aayu-ingredient-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #e6f4ed;
    color: #0e5a36;
    font-size: 1rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 10px;
  }
  .aayu-ingredient-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 1.2rem auto;
    border-radius: 50%;
    background: linear-gradient(135deg, #e6f4ed 0%, #d1fae5 100%);
    color: #0e5a36;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .aayu-ingredient-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.3rem 0;
  }
  .aayu-ingredient-hindi {
    font-size: 1.3rem;
    font-weight: 700;
    color: #cca43b;
    margin: 0 0 0.8rem 0;
  }
  .aayu-ingredient-benefit {
    font-size: 1.3rem;
    color: #4b5563;
    line-height: 1.45;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Ayurvedic Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "100% HERBAL & AYURVEDIC FORMULA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Powerful Natural Ingredients For Fast Relief"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Herb Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Herb Name",
          "default": "Mahanarayan Oil"
        },
        {
          "type": "text",
          "id": "hindi_title",
          "label": "Hindi Name",
          "default": "महानारायण तेल"
        },
        {
          "type": "textarea",
          "id": "benefit",
          "label": "Pain Relief Benefit",
          "default": "Deep muscle relaxation, joint cartilage nourishment, and natural mobility restoration."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ayurvedic Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "title": "Mahanarayan Oil",
            "hindi_title": "महानारायण तेल",
            "benefit": "Deep muscle relaxation, joint cartilage nourishment, and natural mobility restoration."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Gandhapura (Wintergreen)",
            "hindi_title": "गंधपुरा तेल",
            "benefit": "Rich in natural methyl salicylate for rapid, targeted pain numbing and anti-swelling."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Nilgiri (Eucalyptus)",
            "hindi_title": "नीलगिरी तेल",
            "benefit": "Delivers soothing thermal warmth to relieve nerve stiffness and joint inflammation."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Kapur (Camphor)",
            "hindi_title": "कपूर संचित",
            "benefit": "Stimulates local micro-circulation, accelerating tissue healing and fast pain relief."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Shallaki (Boswellia)",
            "hindi_title": "शल्लकी अर्का",
            "benefit": "Time-tested Ayurvedic herb to reduce morning stiffness and preserve joint flexibility."
          }
        }
      ]
    }
  ]
}
{% endschema %}
