{% comment %}
  Aayu Pain - Custom USP Grid (4 Pillars of Relief)
{% endcomment %}

<div id="usp" class="aayu-usp-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="aayu-usp-header text-center">
      {% if section.settings.sub_heading != blank %}
        <span class="aayu-subheading">{{ section.settings.sub_heading | escape }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="aayu-section-heading h1">{{ section.settings.heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="aayu-usp-grid">
      {% for block in section.blocks %}
        <div class="aayu-usp-card" {{ block.shopify_attributes }}>
          <div class="aayu-usp-icon">
            {% if block.settings.icon_svg != blank %}
              {{ block.settings.icon_svg }}
            {% else %}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {% endif %}
          </div>
          <div class="aayu-usp-content">
            <h3 class="aayu-usp-title">{{ block.settings.title | escape }}</h3>
            <p class="aayu-usp-desc">{{ block.settings.description | escape }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .aayu-usp-section {
    border-top: 1px solid rgba(204, 164, 59, 0.2);
    border-bottom: 1px solid rgba(204, 164, 59, 0.2);
    scroll-margin-top: 80px;
  }
  .aayu-subheading {
    display: inline-block;
    color: #cca43b;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  .aayu-section-heading {
    color: #0e5a36;
    margin: 0 0 1rem 0;
  }
  .aayu-usp-header {
    margin-bottom: 3rem;
    text-align: center;
  }
  .aayu-usp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  @media screen and (max-width: 989px) {
    .aayu-usp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 550px) {
    .aayu-usp-grid {
      grid-template-columns: 1fr;
    }
  }
  .aayu-usp-card {
    background: #ffffff;
    border-radius: 12px;
    padding: 1.8rem;
    border: 1px solid rgba(204, 164, 59, 0.2);
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .aayu-usp-card:hover {
    transform: translateY(-3px);
    border-color: #cca43b;
  }
  .aayu-usp-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: #e6f4ed;
    color: #0e5a36;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .aayu-usp-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.5rem 0;
  }
  .aayu-usp-desc {
    font-size: 1.35rem;
    color: #6b7280;
    line-height: 1.4;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "USP Grid (4 Pillars)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "THE AAYU PAIN GUARANTEE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Thousands Trust AyuPain Relief Oil"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#faf7f2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP Pillar",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Pillar Title",
          "default": "100% Ayurvedic Formula"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Pillar Description",
          "default": "Crafted with 48+ pure herbal oils, Mahanarayan & Wintergreen formulation for natural healing."
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Custom SVG Icon (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "USP Grid (4 Pillars)",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "title": "100% Ayurvedic Formula",
            "description": "Certified 48+ herbal ingredients tested for maximum efficacy without side effects."
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Fast Absorbing",
            "description": "Non-greasy, fast-acting deep muscle penetration that starts working in minutes."
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Long Lasting Comfort",
            "description": "Provides all-day joint mobility support and eases morning knee, back & shoulder stiffness."
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Zero Mineral Oil & Chemicals",
            "description": "Free from mineral oil, alcohol, and harmful synthetic toxins. Safe for all age groups."
          }
        }
      ]
    }
  ]
}
{% endschema %}
