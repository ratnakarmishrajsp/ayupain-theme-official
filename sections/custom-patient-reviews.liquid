{% comment %}
  Aayu Pain - Clinical & Patient Reviews Section
{% endcomment %}

<div class="aayu-reviews-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="aayu-reviews-header text-center">
      {% if section.settings.sub_heading != blank %}
        <span class="aayu-subheading">{{ section.settings.sub_heading | escape }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="aayu-section-heading h1">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      <div class="aayu-rating-summary">
        <div class="aayu-stars">★★★★★</div>
        <span class="aayu-rating-text">4.9 / 5.0 Rating based on 10,000+ Happy Patients</span>
      </div>
    </div>

    <div class="aayu-reviews-grid">
      {% for block in section.blocks %}
        <div class="aayu-review-card" {{ block.shopify_attributes }}>
          <div class="aayu-card-top">
            <div class="aayu-review-stars">
              {% assign rating = block.settings.rating | plus: 0 %}
              {% for i in (1..5) %}
                {% if i <= rating %}★{% else %}☆{% endif %}
              {% endfor %}
            </div>
            <span class="aayu-verified-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              Verified Buyer
            </span>
          </div>

          <h3 class="aayu-review-title">{{ block.settings.review_title | escape }}</h3>
          <p class="aayu-review-comment">"{{ block.settings.comment | escape }}"</p>

          <div class="aayu-reviewer-info">
            <div class="aayu-reviewer-avatar">{{ block.settings.author_name | slice: 0 }}</div>
            <div class="aayu-reviewer-details">
              <span class="aayu-author-name">{{ block.settings.author_name | escape }}</span>
              <span class="aayu-author-location">{{ block.settings.location | escape }}</span>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .aayu-reviews-header {
    margin-bottom: 3.5rem;
    text-align: center;
  }
  .aayu-rating-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 1rem;
  }
  .aayu-stars {
    color: #cca43b;
    font-size: 1.8rem;
    letter-spacing: 2px;
  }
  .aayu-rating-text {
    font-size: 1.3rem;
    font-weight: 600;
    color: #374151;
  }
  .aayu-reviews-grid {
    display: grid;
    grid-template-columns: repeat( auto-fit, minmax(300px, 1fr) );
    gap: 2rem;
  }
  .aayu-review-card {
    background: #ffffff;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid rgba(204, 164, 59, 0.25);
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .aayu-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .aayu-review-stars {
    color: #cca43b;
    font-size: 1.6rem;
  }
  .aayu-verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0e5a36;
    background: #e6f4ed;
    padding: 2px 8px;
    border-radius: 12px;
  }
  .aayu-review-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.8rem 0;
  }
  .aayu-review-comment {
    font-size: 1.4rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
    font-style: italic;
  }
  .aayu-reviewer-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .aayu-reviewer-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0e5a36 0%, #166534 100%);
    color: #ffffff;
    font-weight: 700;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .aayu-reviewer-details {
    display: flex;
    flex-direction: column;
  }
  .aayu-author-name {
    font-size: 1.35rem;
    font-weight: 700;
    color: #1f2937;
  }
  .aayu-author-location {
    font-size: 1.15rem;
    color: #6b7280;
  }
</style>

{% schema %}
{
  "name": "Patient Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "REAL PATIENT RECOVERIES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved By Over 10,000+ Customers"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#faf7f2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Patient Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating Stars",
          "default": 5
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review Headline",
          "default": "Knee Pain Relief in 7 Days!"
        },
        {
          "type": "textarea",
          "id": "comment",
          "label": "Review Comment",
          "default": "I was struggling with severe morning knee stiffness for months. After using Aayu Pain Oil for 1 week, I can now walk comfortably without pain!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Patient Name",
          "default": "Ramesh Kumar"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Jaipur, Rajasthan"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Patient Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_title": "Relief From Knee Pain in 7 Days!",
            "comment": "I was suffering from severe knee stiffness for months. After massaging with Aayu Pain oil for 7 days, my pain has reduced drastically. Very effective!",
            "author_name": "Ramesh Sharma",
            "location": "Jaipur, Rajasthan"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_title": "Best Back Pain Relief Oil",
            "comment": "Working long hours caused chronic lower back ache. Aayu Pain oil absorbs quickly without stickiness and gives deep warmth and relief instantly.",
            "author_name": "Sunita Verma",
            "location": "Delhi NCR"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_title": "A Blessing for Elderly Mobility",
            "comment": "Bought this for my 68 year old father who had trouble climbing stairs. He applies it twice daily and feels great comfort in his joints.",
            "author_name": "Vikram Patel",
            "location": "Ahmedabad, Gujarat"
          }
        }
      ]
    }
  ]
}
{% endschema %}
