{% comment %}
  Aayu Pain - 3-Step Pain Relief Application Guide Section
{% endcomment %}

<div class="aayu-guide-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="aayu-guide-header text-center">
      {% if section.settings.sub_heading != blank %}
        <span class="aayu-subheading">{{ section.settings.sub_heading | escape }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="aayu-section-heading h1">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="aayu-section-desc">{{ section.settings.description | escape }}</p>
      {% endif %}
    </div>

    <div class="aayu-guide-grid">
      {% for block in section.blocks %}
        <div class="aayu-guide-card" {{ block.shopify_attributes }}>
          <div class="aayu-guide-number">Step 0{{ forloop.index }}</div>
          <div class="aayu-guide-icon-wrapper">
            {% if block.settings.icon_svg != blank %}
              {{ block.settings.icon_svg }}
            {% else %}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            {% endif %}
          </div>
          <h3 class="aayu-guide-title">{{ block.settings.title | escape }}</h3>
          <p class="aayu-guide-text">{{ block.settings.instruction | escape }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .aayu-guide-section {
    border-bottom: 1px solid rgba(204, 164, 59, 0.2);
  }
  .aayu-guide-header {
    margin-bottom: 3.5rem;
    text-align: center;
  }
  .aayu-guide-grid {
    display: grid;
    grid-template-columns: repeat( auto-fit, minmax(280px, 1fr) );
    gap: 2.5rem;
  }
  .aayu-guide-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 3rem 2rem 2.5rem 2rem;
    position: relative;
    box-shadow: 0 10px 25px -5px rgba(14, 90, 54, 0.08);
    border: 1px solid rgba(204, 164, 59, 0.25);
    text-align: center;
    transition: transform 0.3s ease;
  }
  .aayu-guide-card:hover {
    transform: translateY(-5px);
  }
  .aayu-guide-number {
    position: absolute;
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #0e5a36 0%, #166534 100%);
    color: #ffffff;
    font-size: 1.3rem;
    font-weight: 800;
    padding: 6px 18px;
    border-radius: 20px;
    box-shadow: 0 4px 10px rgba(14, 90, 54, 0.2);
  }
  .aayu-guide-icon-wrapper {
    width: 70px;
    height: 70px;
    margin: 1rem auto 1.5rem auto;
    background: #e6f4ed;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0e5a36;
  }
  .aayu-guide-title {
    font-size: 1.9rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 1rem 0;
  }
  .aayu-guide-text {
    font-size: 1.45rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Application Guide",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "EASY 3-STEP DAILY ROUTINE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How To Apply Aayu Pain Relief Oil"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Follow these simple steps twice daily for rapid absorption and long-lasting joint & muscle comfort."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Application Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Warm The Oil"
        },
        {
          "type": "textarea",
          "id": "instruction",
          "label": "Step Instruction",
          "default": "Take 5 to 10 drops of Aayu Pain Relief Oil on your palm and rub gently between hands to activate herbal essential oils."
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Custom SVG Icon (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Application Guide",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Warm 5-10 Drops",
            "instruction": "Pour 5 to 10 drops of oil onto your palm and rub palms together gently to warm up the Ayurvedic formulation."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Gentle Massage (3-5 Mins)",
            "instruction": "Dab onto joint or sore muscle area and massage gently in clockwise circular motion for 3 to 5 minutes until absorbed."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Twice Daily Application",
            "instruction": "Apply twice daily (once in the morning and once before bedtime) for continuous mobility and zero morning stiffness."
          }
        }
      ]
    }
  ]
}
{% endschema %}
