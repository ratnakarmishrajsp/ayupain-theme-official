{% comment %}
  Aayu Pain - 3-Step Pain Relief Application Guide Section
{% endcomment %}

<div class="aayu-guide-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="aayu-guide-header text-center">
      {% if section.settings.sub_heading != blank %}
        <span class="aayu-subheading">{{ section.settings.sub_heading | escape }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="aayu-section-heading h1">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      <p class="aayu-section-desc">Follow these 3 simple daily steps for fast deep-penetration relief from joint & muscle stiffness.</p>
    </div>

    <div class="aayu-guide-grid">
      {% for block in section.blocks %}
        <div class="aayu-guide-card" {{ block.shopify_attributes }}>
          <div class="aayu-guide-number">Step 0{{ forloop.index }}</div>
          <div class="aayu-guide-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3 class="aayu-guide-title">{{ block.settings.title | escape }}</h3>
          <p class="aayu-guide-text">{{ block.settings.instruction | escape }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .aayu-guide-section {
    border-bottom: 1px solid rgba(204, 164, 59, 0.2);
  }
  .aayu-subheading {
    display: inline-block;
    color: #cca43b;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  .aayu-section-heading {
    color: #0e5a36;
    margin: 0 0 0.5rem 0;
  }
  .aayu-section-desc {
    font-size: 1.5rem;
    color: #4b5563;
    max-width: 650px;
    margin: 0 auto;
  }
  .aayu-guide-header {
    margin-bottom: 3.5rem;
    text-align: center;
  }
  .aayu-guide-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media screen and (max-width: 768px) {
    .aayu-guide-grid {
      grid-template-columns: 1fr;
    }
  }
  .aayu-guide-card {
    background: #ffffff;
    border-radius: 14px;
    padding: 2.5rem 2rem;
    border: 1px solid rgba(204, 164, 59, 0.25);
    box-shadow: 0 8px 20px rgba(0,0,0,0.04);
    text-align: center;
    position: relative;
  }
  .aayu-guide-number {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #0e5a36 0%, #166534 100%);
    color: #cca43b;
    font-size: 1.3rem;
    font-weight: 800;
    padding: 4px 16px;
    border-radius: 20px;
    border: 2px solid #cca43b;
  }
  .aayu-guide-icon-wrapper {
    width: 60px;
    height: 60px;
    margin: 1rem auto 1.5rem auto;
    border-radius: 50%;
    background: #e6f4ed;
    color: #0e5a36;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .aayu-guide-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.8rem 0;
  }
  .aayu-guide-text {
    font-size: 1.4rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Application Guide",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "EASY 3-STEP DAILY ROUTINE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How To Apply AyuPain Relief Oil"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#faf7f2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Application Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Warm 5-10 Drops"
        },
        {
          "type": "textarea",
          "id": "instruction",
          "label": "Step Instruction",
          "default": "Pour 5 to 10 drops of oil onto your palm and rub palms together gently to warm up the Ayurvedic formulation."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Application Guide",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Warm 5-10 Drops",
            "instruction": "Pour 5 to 10 drops of oil onto your palm and rub palms together gently to warm up the Ayurvedic formulation."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Gentle Massage (3-5 Mins)",
            "instruction": "Dab onto joint or sore muscle area and massage gently in clockwise circular motion for 3 to 5 minutes until absorbed."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Twice Daily Application",
            "instruction": "Apply twice daily (once in the morning and once before bedtime) for continuous mobility and zero morning stiffness."
          }
        }
      ]
    }
  ]
}
{% endschema %}
