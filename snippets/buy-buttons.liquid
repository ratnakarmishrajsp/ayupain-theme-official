{% comment %}
  Renders product buy-buttons with Direct Checkout Prepaid CTA & Ultra Premium Color Grading.
{% endcomment %}
<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      if block.settings.show_gift_card_recipient and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif

      assign show_dynamic_checkout = false
      if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      endif
    -%}

    <product-form
      class="product-form"
      data-hide-errors="{{ gift_card_recipient_feature_active }}"
      data-section-id="{{ section.id }}"
    >
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <span class="svg-wrapper">
          {{- 'icon-error.svg' | inline_asset_content -}}
        </span>
        <span class="product-form__error-message"></span>
      </div>

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          {% if product.selected_or_first_available_variant.available == false
            or quantity_rule_soldout
            or product.selected_or_first_available_variant == null
          %}
            disabled
          {% endif %}
          class="product-variant-id"
        >
        <!-- Return to checkout input for Direct Checkout -->
        <input type="hidden" name="return_to" value="/checkout" id="returnToCheckoutInput-{{ section_id }}">

        {%- if gift_card_recipient_feature_active -%}
          {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
        {%- endif -%}

        <div class="product-form__buttons" style="display: flex; flex-direction: column; gap: 10px;">
          {%- liquid
            assign check_against_inventory = true
            if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
              assign check_against_inventory = false
            endif
            if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
              assign quantity_rule_soldout = true
            endif
          -%}
          
          <!-- 1. Topmost Add to Cart Button -->
          <button
            id="AddToCartSubmitButton-{{ section_id }}"
            type="submit"
            name="add"
            class="product-form__submit button button--full-width btn-add-to-cart-styled"
            onclick="if(document.getElementById('returnToCheckoutInput-{{ section_id }}')) document.getElementById('returnToCheckoutInput-{{ section_id }}').value='';"
            {% if product.selected_or_first_available_variant.available == false
              or quantity_rule_soldout
              or product.selected_or_first_available_variant == null
            %}
              disabled
            {% endif %}
          >
            <span class="btn-atc-main">
              {%- if product.selected_or_first_available_variant.available == false or quantity_rule_soldout -%}
                {{ 'products.product.sold_out' | t }}
              {%- else -%}
                🛒 ADD TO CART
              {%- endif -%}
            </span>
            {%- render 'loading-spinner' -%}
          </button>

          <!-- 2. Middle Prepaid Discount Button -> Direct Checkout -->
          <button
            id="ProductSubmitButton-{{ section_id }}"
            type="submit"
            name="add"
            class="product-form__submit button button--full-width btn-prepaid-highlight"
            onclick="if(document.getElementById('returnToCheckoutInput-{{ section_id }}')) document.getElementById('returnToCheckoutInput-{{ section_id }}').value='/checkout';"
            {% if product.selected_or_first_available_variant.available == false
              or quantity_rule_soldout
              or product.selected_or_first_available_variant == null
            %}
              disabled
            {% endif %}
          >
            <div class="btn-prepaid-content">
              <div class="btn-prepaid-header">
                <span class="btn-flash-icon">⚡</span>
                <span class="btn-prepaid-main">PAY ONLINE - GET INSTANT ₹100 OFF</span>
              </div>
            </div>
            {%- render 'loading-spinner' -%}
          </button>

          {%- if show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>
  {%- else -%}
    <div class="product-form">
      <div class="product-form__buttons form">
        <button
          type="submit"
          name="add"
          class="product-form__submit button button--full-width button--primary"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="product__pickup-availabilities quick-add-hidden"
      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
      data-product-page-color-scheme="gradient color-{{ section.settings.color_scheme }}"
    >
      <template>
        <pickup-availability-preview class="pickup-availability-preview">
          <span class="svg-wrapper">
            {{- 'icon-unavailable.svg' | inline_asset_content -}}
          </span>
          <div class="pickup-availability-info">
            <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
            <button class="pickup-availability-button link link--text underlined-link">
              {{ 'products.product.pickup_availability.refresh' | t }}
            </button>
          </div>
        </pickup-availability-preview>
      </template>
    </pickup-availability>

    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>

<style>
  /* Mobile-Optimized Add To Cart Button */
  .btn-add-to-cart-styled {
    background: #0e5a36 !important;
    color: #ffffff !important;
    border: 2px solid #0e5a36 !important;
    border-radius: 12px !important;
    padding: 1.1rem 1.6rem !important;
    min-height: 52px !important;
    font-size: 1.5rem !important;
    font-weight: 800 !important;
    letter-spacing: 0.8px !important;
    text-transform: uppercase !important;
    box-shadow: 0 4px 15px rgba(14, 90, 54, 0.25) !important;
    transition: all 0.25s ease !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    width: 100% !important;
  }
  .btn-add-to-cart-styled:hover {
    background: #093f25 !important;
    border-color: #cca43b !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 20px rgba(14, 90, 54, 0.4) !important;
  }
  .btn-atc-main {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.8px;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  /* Ultra-Premium Color Graded Prepaid Discount Button */
  .btn-prepaid-highlight {
    position: relative !important;
    background: linear-gradient(135deg, #07341e 0%, #0e5a36 50%, #15803d 100%) !important;
    color: #ffffff !important;
    border: 2px solid #cca43b !important;
    border-radius: 12px !important;
    padding: 1.1rem 1.6rem !important;
    min-height: 52px !important;
    box-shadow: 0 8px 25px -4px rgba(14, 90, 54, 0.45), 0 0 15px rgba(204, 164, 59, 0.25) !important;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
    cursor: pointer;
    overflow: hidden !important;
    width: 100% !important;
  }
  .btn-prepaid-highlight::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.25) 50%,
      transparent 100%
    );
    transform: skewX(-25deg);
    animation: btnShimmer 3.5s infinite;
  }
  @keyframes btnShimmer {
    0% { left: -100%; }
    30% { left: 180%; }
    100% { left: 180%; }
  }
  .btn-prepaid-highlight:hover {
    transform: translateY(-3px) scale(1.005) !important;
    background: linear-gradient(135deg, #042414 0%, #093f25 50%, #0e5a36 100%) !important;
    border-color: #fef08a !important;
    box-shadow: 0 12px 30px -4px rgba(14, 90, 54, 0.6), 0 0 20px rgba(204, 164, 59, 0.4) !important;
  }
  .btn-prepaid-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .btn-prepaid-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .btn-flash-icon {
    font-size: 1.8rem;
    color: #fcd34d;
    filter: drop-shadow(0 0 6px rgba(252, 211, 77, 0.6));
    animation: pulse 1.5s infinite;
  }
  .btn-prepaid-main {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.8px;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  /* Pulse Glow Animation for Releasit COD Order Now Button */
  @keyframes releasitCodPulse {
    0% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(204, 164, 59, 0.75), 0 6px 20px -3px rgba(14, 90, 54, 0.4);
    }
    50% {
      transform: scale(1.02);
      box-shadow: 0 0 0 10px rgba(204, 164, 59, 0), 0 10px 25px -3px rgba(14, 90, 54, 0.6);
    }
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(204, 164, 59, 0), 0 6px 20px -3px rgba(14, 90, 54, 0.4);
    }
  }

  /* Ultra-Premium Color Grading & Pulse for Relish / Releasit COD App Buttons (EXCLUDING close buttons) */
  div[class*="releasit"] button:not([class*="close"]):not([id*="close"]):not([aria-label*="close"]):not(.close),
  div[id*="releasit"] button:not([class*="close"]):not([id*="close"]):not([aria-label*="close"]):not(.close),
  div[class*="relish"] button:not([class*="close"]):not([id*="close"]):not([aria-label*="close"]):not(.close),
  div[id*="relish"] button:not([class*="close"]):not([id*="close"]):not([aria-label*="close"]):not(.close),
  .releasit-button,
  .releasit-cod-button,
  .relish-button,
  .relish-cod-button,
  [data-releasit-button],
  [data-relish-button],
  div[class*="cod-"] button:not([class*="close"]),
  button[class*="cod-"]:not([class*="close"]),
  .shopify-app-block button:not([class*="close"]),
  .product-form__buttons + div button:not([class*="close"]),
  div.product-form__buttons ~ div button:not([class*="close"]) {
    background: linear-gradient(135deg, #093f25 0%, #0e5a36 60%, #166534 100%) !important;
    color: #ffffff !important;
    border: 2px solid #cca43b !important;
    border-radius: 12px !important;
    font-weight: 800 !important;
    font-size: 1.5rem !important;
    letter-spacing: 0.5px !important;
    padding: 1.1rem 1.6rem !important;
    min-height: 52px !important;
    box-shadow: 0 6px 20px -3px rgba(14, 90, 54, 0.4), 0 0 12px rgba(204, 164, 59, 0.2) !important;
    transition: all 0.25s ease !important;
    text-transform: uppercase !important;
    width: 100% !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    margin-top: 2px !important;
    animation: releasitCodPulse 2.2s infinite ease-in-out !important;
  }

  div[class*="releasit"] button:not([class*="close"]):hover,
  div[id*="releasit"] button:not([class*="close"]):hover,
  div[class*="relish"] button:not([class*="close"]):hover,
  div[id*="relish"] button:not([class*="close"]):hover,
  .releasit-button:hover,
  .releasit-cod-button:hover,
  .relish-button:hover,
  .relish-cod-button:hover,
  [data-releasit-button]:hover,
  [data-relish-button]:hover,
  div[class*="cod-"] button:not([class*="close"]):hover,
  button[class*="cod-"]:not([class*="close"]):hover,
  .shopify-app-block button:not([class*="close"]):hover,
  .product-form__buttons + div button:not([class*="close"]):hover,
  div.product-form__buttons ~ div button:not([class*="close"]):hover {
    background: linear-gradient(135deg, #042414 0%, #093f25 60%, #0e5a36 100%) !important;
    border-color: #fef08a !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 10px 25px -3px rgba(14, 90, 54, 0.55), 0 0 18px rgba(204, 164, 59, 0.35) !important;
  }

  div[class*="releasit"] button:not([class*="close"]) *,
  div[id*="releasit"] button:not([class*="close"]) *,
  div[class*="relish"] button:not([class*="close"]) *,
  div[id*="relish"] button:not([class*="close"]) *,
  .releasit-button *,
  .relish-button *,
  .shopify-app-block button:not([class*="close"]) * {
    color: #ffffff !important;
    font-weight: 800 !important;
  }

  /* Releasit Modal Close (X) Icon Fix */
  div[class*="releasit"] button[class*="close"],
  div[id*="releasit"] button[class*="close"],
  div[class*="releasit"] [class*="close"],
  div[id*="releasit"] [class*="close"],
  .releasit-modal-close,
  .releasit-close,
  .releasit-close-btn {
    width: 32px !important;
    height: 32px !important;
    min-height: 32px !important;
    max-width: 32px !important;
    max-height: 32px !important;
    padding: 0 !important;
    margin: 0 !important;
    background: rgba(0, 0, 0, 0.12) !important;
    color: #1f2937 !important;
    border: 1px solid #d1d5db !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    pointer-events: auto !important;
    z-index: 9999999 !important;
    font-size: 18px !important;
    font-weight: 700 !important;
  }

  /* Hide duplicate 'Add' or 'Add to Cart' button rendered inside COD App blocks (Releasit/Relish/Shiprocket) */
  .shopify-app-block button.secondary,
  .shopify-app-block .releasit-add-to-cart,
  .shopify-app-block .relish-add-to-cart,
  .releasit-secondary-button,
  .relish-secondary-button,
  [data-releasit-type="add-to-cart"],
  [data-relish-type="add-to-cart"] {
    display: none !important;
  }
</style>

<script>
  (function() {
    function hideDuplicateAppAddButtons() {
      const appContainers = document.querySelectorAll('.shopify-app-block, div[class*="releasit"], div[id*="releasit"], div[class*="relish"], div[id*="relish"], [class*="cod-"]');
      appContainers.forEach(function(container) {
        const buttons = container.querySelectorAll('button, a.btn, div[role="button"]');
        if (buttons.length > 1) {
          buttons.forEach(function(btn, idx) {
            const text = (btn.textContent || '').trim().toLowerCase();
            if ((text === 'add' || text === 'add to cart' || text.startsWith('add ')) && !text.includes('delivery') && !text.includes('cod') && !text.includes('cash')) {
              btn.style.setProperty('display', 'none', 'important');
            }
          });
        } else if (buttons.length === 1) {
          const btn = buttons[0];
          const text = (btn.textContent || '').trim().toLowerCase();
          if ((text === 'add' || text === 'add to cart') && !text.includes('delivery') && !text.includes('cod')) {
            btn.style.setProperty('display', 'none', 'important');
          }
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', hideDuplicateAppAddButtons);
    } else {
      hideDuplicateAppAddButtons();
    }
    window.addEventListener('load', hideDuplicateAppAddButtons);
    setTimeout(hideDuplicateAppAddButtons, 300);
    setTimeout(hideDuplicateAppAddButtons, 1000);
    setTimeout(hideDuplicateAppAddButtons, 2500);

    try {
      const observer = new MutationObserver(function() {
        hideDuplicateAppAddButtons();
      });
      observer.observe(document.body, { childList: true, subtree: true });
    } catch(e) {}
  })();
</script>
